// prisma/schema.prisma
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum UserRole {
  CLIENT
  CONTRACTOR
  ADMIN
  BUSINESS
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_TALK
  CLOSED
  ARCHIVED
}

enum Plan {
  FREE
  PRO
}

enum CompanyPurpose {
  LOGISTICS
  SERVICES
  GOODS
}

enum CompanyRole {
  HEAD // владелец / создатель
  MANAGEMENT // менеджмент
  EMPLOYEE // обычный сотрудник
}

model City {
  id        String   @id @default(cuid())
  slug      String   @unique // latin-slug: almaty, astana, ...
  nameRu    String
  nameKk    String?
  nameEn    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // обратные связи
  users       User[]
  contractors Contractor[]
  projects    Project[]

  @@index([nameRu])
  @@index([nameKk])
  @@index([slug])
}

// ========= Models =========
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      UserRole @default(CLIENT)

  email        String? @unique
  phone        String? @unique
  passwordHash String?
  name         String?
  avatarUrl    String?

  contractor Contractor?

  projects Project[] @relation("UserProjects")

  messages Message[] @relation("UserMessages")

  plan                 Plan                   @default(FREE)
  planUntil            DateTime?
  isBanned             Boolean                @default(false)
  Conversation         Conversation[]
  Subscription         Subscription[]
  City                 City?                  @relation(fields: [cityId], references: [id])
  cityId               String?
  favorite             Favorite[]
  favoriteContractor   FavoriteContractor[]
  review               Review[]
  Notification         Notification[]
  ProjectStatusHistory ProjectStatusHistory[]
  ProjectView          ProjectView[]
  CompanyEmployee      CompanyEmployee[]
  Company              Company[]
}

model Contractor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  companyName String?
  about       String?

  cityId String?
  city   City?   @relation(fields: [cityId], references: [id], onDelete: SetNull)

  // 🔹 связь с компанией
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  categories           Category[]             @relation("ContractorCategories")
  conversations        Conversation[]
  ContractorAttachment ContractorAttachment[]

  services                ContractorService[]
  ContractorShowcaseImage ContractorShowcaseImage[]
  favorites               FavoriteContractor[]
  review                  Review[]
  ProjectStatusHistory    ProjectStatusHistory[]
  Project                 Project[]

  @@index([cityId])
  @@index([companyId])
}

model CompanyEmployee {
  id String @id @default(cuid())

  companyId String
  userId    String

  position String?
  isActive Boolean @default(true)

  // 🔹 роль внутри компании
  role CompanyRole @default(EMPLOYEE)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([companyId, userId])
  @@index([userId])
}

model Company {
  id          String  @id @default(cuid())
  name        String
  description String?

  // назначение компании: логистика, услуги, товары
  purpose CompanyPurpose

  // логотип
  logoUrl String? @map("logo_url")

  images CompanyImage[]

  manager   User              @relation(fields: [userId], references: [id])
  // сотрудники
  employees CompanyEmployee[]

  // исполнители (если нужно связать Contractor с компанией)
  contractors Contractor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
}

model CompanyImage {
  id String @id @default(cuid())

  companyId String
  url       String // ссылка на картинку (MinIO / S3 / CDN / что угодно)

  isMain    Boolean @default(false) // главное изображение
  sortOrder Int     @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId])
}

model ContractorService {
  id           String   @id @default(cuid())
  contractorId String
  serviceId    String
  createdAt    DateTime @default(now())

  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  selectedCategories ContractorServiceSelectedCategory[]

  @@unique([contractorId, serviceId])
  @@index([contractorId])
  @@index([serviceId])
}

model ContractorServiceSelectedCategory {
  contractorServiceId String
  categoryId          String

  contractorService ContractorService @relation(fields: [contractorServiceId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([contractorServiceId, categoryId])
  @@index([categoryId])
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  iconUrl     String?  @map("icon_url") // 🔹 иконка
  isCoverser  Boolean  @default(false) @map("is_coverser") // 🔹 на обложке
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories Category[] @relation("ServiceCategories")

  projectLinks    ProjectService[]
  contractorLinks ContractorService[]
}

model Category {
  id   String @id @default(cuid())
  name String @unique

  projects    Project[]    @relation("ProjectCategories")
  contractors Contractor[] @relation("ContractorCategories")
  services    Service[]    @relation("ServiceCategories")

  projectServiceSelections    ProjectServiceSelectedCategory[]
  contractorServiceSelections ContractorServiceSelectedCategory[]
}

enum PremisesType {
  APARTMENT
  HOUSE
  OFFICE
  RETAIL
  WAREHOUSE
  OTHER
}

model Project {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  status    ProjectStatus @default(OPEN)

  clientId String
  client   User   @relation("UserProjects", fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String

  coverAttachmentId String?
  coverAttachment   Attachment?      @relation("ProjectCover", fields: [coverAttachmentId], references: [id], onDelete: SetNull)
  services          ProjectService[]
  attachments       Attachment[]

  // ← добавили обратную сторону связи к Category
  categories   Category[]     @relation("ProjectCategories")
  Conversation Conversation[]

  propertyType         PremisesType?
  area                 Float? // площадь (кв. м)
  budgetEstimated      Int? // предполагаемый бюджет (например, KZT)
  cityId               String?
  city                 City?                  @relation(fields: [cityId], references: [id], onDelete: SetNull)
  ProjectShowcaseImage ProjectShowcaseImage[]
  favorite             Favorite[]
  review               Review[]
  ProjectStatusHistory ProjectStatusHistory[]

  responsibleContractorId String?
  responsibleContractor   Contractor?   @relation(fields: [responsibleContractorId], references: [id], onDelete: SetNull)
  ProjectView             ProjectView[]

  @@index([clientId])
  @@index([propertyType])
  @@index([area])
  @@index([budgetEstimated])
}

model ProjectStatusHistory {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  from ProjectStatus?
  to   ProjectStatus

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  // какой специалист занимался проектом на момент перехода
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)

  comment   String?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([changedById])
  @@index([contractorId])
}

model ProjectService {
  id        String   @id @default(cuid())
  projectId String
  serviceId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // выбранные категории этого Service именно для данного Project
  selectedCategories ProjectServiceSelectedCategory[]

  @@unique([projectId, serviceId]) // чтобы одна и та же услуга не дублировалась в проекте
  @@index([projectId])
  @@index([serviceId])
}

model ProjectServiceSelectedCategory {
  projectServiceId String
  categoryId       String

  projectService ProjectService @relation(fields: [projectServiceId], references: [id], onDelete: Cascade)
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([projectServiceId, categoryId]) // уникальность выбранной категории для связки
  @@index([categoryId])
}

model Attachment {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url       String
  mime      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  coverOf                 Project[]                 @relation("ProjectCover")
  ProjectShowcaseImage    ProjectShowcaseImage[]
  ContractorShowcaseImage ContractorShowcaseImage[]

  @@index([projectId, sortOrder])
}

model ContractorAttachment {
  id                      String                    @id @default(uuid())
  contractorId            String
  filename                String
  path                    String
  mimetype                String?
  size                    Int?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  Contractor              Contractor                @relation(fields: [contractorId], references: [id])
  ContractorShowcaseImage ContractorShowcaseImage[]
}

model Conversation {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, clientId, contractorId])
  @@index([projectId])
  @@index([clientId])
  @@index([contractorId])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  senderId String
  sender   User   @relation("UserMessages", fields: [senderId], references: [id])

  text          String?
  attachmentUrl String?
  fileUrl       String? // путь в MinIO
  fileName      String?
  fileMime      String?
  fileSize      Int?
  readAt        DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  plan       Plan
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  paymentRef String?
  isActive   Boolean  @default(true)

  @@index([userId])
  @@index([isActive, expiresAt])
}

model ProjectShowcaseImage {
  id           String @id @default(cuid())
  projectId    String
  attachmentId String
  position     Int

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id])

  @@unique([projectId, position])
  @@unique([projectId, attachmentId])
}

model ContractorShowcaseImage {
  id                     String @id @default(cuid())
  contractorId           String
  contractorAttachmentId String // было: attachmentId
  position               Int

  contractor           Contractor           @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  contractorAttachment ContractorAttachment @relation(fields: [contractorAttachmentId], references: [id])
  Attachment           Attachment?          @relation(fields: [attachmentId], references: [id])
  attachmentId         String?

  @@unique([contractorId, position])
  @@unique([contractorId, contractorAttachmentId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId], name: "uniq_favorite_user_project")
  @@index([userId, createdAt])
}

model FavoriteContractor {
  id           String   @id @default(cuid())
  userId       String
  contractorId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@unique([userId, contractorId], name: "uniq_favorite_user_contractor")
  @@index([userId, createdAt])
}

enum ReviewStatus {
  PENDING // ждёт публикации
  PUBLISHED // опубликован
  REJECTED // если потом захочешь ручную модерацию
}

model ReviewAttachment {
  id        String   @id @default(cuid())
  reviewId  String
  url       String // путь/ключ в MinIO, например "reviews/1731-uuid.png"
  mime      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, sortOrder])
}

model Review {
  id           String @id @default(cuid())
  userId       String
  contractorId String
  projectId    String

  rating      Int
  text        String       @db.Text
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  publishedAt DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  attachments ReviewAttachment[]

  // уникальность user + contractor + project (если она тебе всё ещё нужна)
  @@unique([userId, contractorId, projectId], map: "uniq_review_user_contractor_project")
  // индекс по contractorId + createdAt
  @@index([contractorId, createdAt], map: "review_contractorId_createdAt_idx")
}

enum NotificationType {
  INFO
  ALERT
}

enum NotificationStatus {
  UNREAD // для info
  READ // для info
  PENDING // для alert
  ACCEPTED // для alert
  REJECTED // для alert
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  status    NotificationStatus
  title     String?
  message   String
  data      Json? // произвольный payload для фронта/логики
  createdAt DateTime           @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ProjectView {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // для анонимных: хэш IP + User-Agent
  fingerprint String?

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@unique([projectId, fingerprint])
  @@index([projectId])
}
