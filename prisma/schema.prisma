// prisma/schema.prisma
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ========= Enums =========
enum UserRole {
  CLIENT
  CONTRACTOR
  ADMIN
}

enum ProjectStatus {
  OPEN
  IN_TALK
  CLOSED
  ARCHIVED
}

enum Plan {
  FREE
  PRO
}

// ========= Models =========
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      UserRole @default(CLIENT)

  email        String? @unique
  phone        String? @unique
  passwordHash String?
  name         String?
  city         String?
  avatarUrl    String?

  contractor Contractor?

  // one-to-many: user -> projects (как «клиент/владелец»)
  projects Project[] @relation("UserProjects")

  // one-to-many: user -> messages (как «sender»)
  messages Message[] @relation("UserMessages")

  plan         Plan           @default(FREE)
  planUntil    DateTime?
  isBanned     Boolean        @default(false)
  Conversation Conversation[]
  Subscription Subscription[]
}

model Contractor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  companyName String?
  about       String?

  categories           Category[]             @relation("ContractorCategories")
  conversations        Conversation[] // удобная обратная связь (через relation ниже)
  ContractorAttachment ContractorAttachment[]
}

model Category {
  id   String @id @default(cuid())
  name String @unique

  projects    Project[]    @relation("ProjectCategories")
  contractors Contractor[] @relation("ContractorCategories")
}

model Project {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  status    ProjectStatus @default(OPEN)

  // владелец проекта (клиент)
  clientId String
  client   User   @relation("UserProjects", fields: [clientId], references: [id])

  title         String
  description   String
  placeType     String
  areaM2        Int?
  budgetMin     Int?
  budgetMax     Int?
  city          String?
  categories    Category[]     @relation("ProjectCategories")
  attachments   Attachment[]
  conversations Conversation[]

  @@index([status, city])
  @@index([clientId])
}

model Attachment {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  url       String
  mime      String
  width     Int?
  height    Int?
  sizeBytes Int?

  caption   String?
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)
  objectKey String  @unique
  checksum  String? @unique

  createdAt DateTime @default(now()) // ← добавили

  @@index([projectId, sortOrder])
}

model ContractorAttachment {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  url       String
  mime      String
  width     Int?
  height    Int?
  sizeBytes Int?

  caption   String?
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)
  objectKey String  @unique
  checksum  String? @unique

  createdAt DateTime @default(now())

  @@index([contractorId, sortOrder])
}

model Conversation {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  messages Message[]

  @@unique([projectId, clientId, contractorId])
  @@index([projectId])
  @@index([clientId])
  @@index([contractorId])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  senderId String
  sender   User   @relation("UserMessages", fields: [senderId], references: [id])

  text          String?
  attachmentUrl String?
  readAt        DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  plan       Plan
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  paymentRef String?
  isActive   Boolean  @default(true)

  @@index([userId])
  @@index([isActive, expiresAt])
}
